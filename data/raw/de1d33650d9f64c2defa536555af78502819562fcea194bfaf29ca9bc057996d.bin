<script>
    $(document).ready(function(){
        // 进入页面埋点
        if (typeof sendBehaviorLog === 'function') {
            sendBehaviorLog('enterPage', {
                type: '5200401101',
                typeName: '进入-招标信息列表页'
            });
        }
        $('#J_main_nav_link li a').on('click', function(e) {
            var tab = $(this).text().trim() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401203',
                    typeName: '点击-招标信息列表页-列表tab',
                    value: {
                        tab: tab
                    }
                });
            }
        });

        // 招标信息列表页-项目地区点击埋点
        $('.select-province-block input[name=provinceId]').on('click', function(e) {
            var areaId = $(this).val() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401204',
                    typeName: '点击-招标信息列表页-项目地区',
                    value: {
                        areaId: areaId
                    }
                });
            }
        });

        // 招标信息列表页-删除所选地区点击埋点
        $(document).on('click', '.has-selected-item.area img', function(e) {
            // 不阻止事件冒泡，让删除逻辑可以正常执行
            var areaId = $(this).siblings('span').attr('data-id') || $(this).siblings('span').text() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401215',
                    typeName: '点击-招标信息列表页-删除所选地区',
                    value: {
                        areaId: areaId
                    }
                });
            }
        });

        // 招标信息列表页-招标内容点击埋点
        $('input[name=noticeType]').on('click', function(e) {
            var noticeType = $(this).val() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401205',
                    typeName: '点击-招标信息列表页-招标内容',
                    value: {
                        noticeType: noticeType
                    }
                });
            }
        });

        // 招标信息列表页-招标进度点击埋点
        $('input[name=invitedBidType]').on('click', function(e) {
            var invitedBidType = $(this).val() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401206',
                    typeName: '点击-招标信息列表页-招标进度',
                    value: {
                        invitedBidType: invitedBidType
                    }
                });
            }
        });

        // 招标信息列表页-筛选条件点击埋点（监听表单提交）
        $('#searchForm').on('submit', function(e) {
            var keyword = $('input[name=keyword]').val() || '';
            var areaIds = [];
            $('input[name=provinceId]:checked').each(function() {
                areaIds.push($(this).val());
            });
            var areaId = areaIds.join(',') || '';
            var noticeType = $('input[name=noticeType]:checked').val() || '';
            var invitedBidType = $('input[name=invitedBidType]:checked').val() || '';
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401207',
                    typeName: '点击-招标信息列表页-筛选条件',
                    value: {
                        keyword: keyword,
                        areaId: areaId,
                        noticeType: noticeType,
                        invitedBidType: invitedBidType
                    }
                });
            }
        });

        // 招标信息列表页-列表点击埋点
        $('.firstTdAAA').on('click', function(e) {
            var href = $(this).attr('href') || '';
            var contentId = '';
            // 从href中提取contentId，格式：/inviteBid/detail/20240101_123456.html
            var match = href.match(/_(\d+)\.html/);
            if (match && match[1]) {
                contentId = match[1];
            }
            
            // 发送点击埋点
            if (typeof sendBehaviorLog === 'function') {
                sendBehaviorLog('click', {
                    type: '5200401208',
                    typeName: '点击-招标信息列表页-列表',
                    value: {
                        contentId: contentId
                    }
                });
            }
        });

        // 招标信息列表页-列表翻页器点击埋点
        // 拦截page函数以获取翻页信息
        if (typeof window.page === 'function') {
            var originalPage = window.page;
            window.page = function(n, s) {
                var oldPage = $('#pageNo').val() || '1';
                var newPage = String(n || '1');
                
                // 发送点击埋点
                if (typeof sendBehaviorLog === 'function') {
                    sendBehaviorLog('click', {
                        type: '5200401209',
                        typeName: '点击-招标信息列表页-列表翻页器',
                        value: {
                            oldPage: oldPage,
                            newPage: newPage
                        }
                    });
                }
                
                // 调用原始函数
                return originalPage.apply(this, arguments);
            };
        }
        
        // 备用方案：监听翻页链接点击
        $(document).on('click', '.pagination a', function(e) {
            var oldPage = $('#pageNo').val() || '1';
            var newPage = oldPage;
            
            // 尝试从onclick中提取页码
            var onclickAttr = $(this).attr('onclick') || '';
            if (onclickAttr) {
                var pageMatch = onclickAttr.match(/page\((\d+)/);
                if (pageMatch && pageMatch[1]) {
                    newPage = pageMatch[1];
                }
            }
            
            // 如果已经通过page函数发送了埋点，这里就不重复发送
            // 这个主要是作为备用方案
        });
    })
</script>

	










<style>
	.footer {
		width: 100%;
		background: #061022;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.4);
		line-height: 18px;
	}

	.footer_mid {
		max-width: 1200px;
		margin: 0 auto;
		padding: 20px 0;
	}

	.footer-content {
		display: -webkit-box;
		display: -ms-flexbox;
		display: -webkit-flex;
		display: flex;
		-webkit-box-pack: justify;
		-ms-flex-pack: space-between;
		-webkit-justify-content: space-between;
		justify-content: space-between;
	}

	.footer-links-section {
		-ms-flex: 1;
		-webkit-flex: 1;
		flex: 1;
	}

	.footer-links-title {
		font-size: 16px;
		font-weight: 500;
		color: #ffffff;
		letter-spacing: 0.5px;
		margin-bottom: 20px;
	}

	.footer-links-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 10px 20px;
		row-gap: 12px;
	}

	.footer-links-grid a {
		color: #b8b8b8;
		text-decoration: none;
		font-size: 13px;
		line-height: 2;
		display: block;
		transition: color 0.2s ease;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.footer-links-grid a:hover {
		color: #ffffff;
	}

	.footer-divider {
		width: 1px;
		background: rgba(255, 255, 255, 0.15);
		margin: 40px 40px 0 40px;
		height: 40px;
	}

	.footer-statement-title {
		font-size: 16px;
		font-weight: 500;
		color: #ffffff;
		margin-bottom: 25px;
		letter-spacing: 0.5px;
	}

	.footer-statement-links {
		display: -webkit-box;
		display: -ms-flexbox;
		display: -webkit-flex;
		display: flex;
		-webkit-box-direction: normal;
		-webkit-box-orient: vertical;
		-ms-flex-direction: column;
		-webkit-flex-direction: column;
		flex-direction: column;
		gap: 14px;
	}

	.footer-statement-links a {
		color: #b8b8b8;
		text-decoration: none;
		font-size: 13px;
		line-height: 2;
		transition: color 0.2s ease;
	}

	.footer-statement-links a:hover {
		color: #ffffff;
	}

	.footer-qrcode-section {
		display: -webkit-box;
		display: -ms-flexbox;
		display: -webkit-flex;
		display: flex;
		gap: 30px;
		-webkit-box-align: start;
		-ms-flex-align: flex-start;
		-webkit-align-items: flex-start;
		align-items: flex-start;
		-webkit-flex-shrink: 0;
		-ms-flex-negative: 0;
		flex-shrink: 0;
	}

	.footer-qrcode-item {
		text-align: center;
	}

	.footer-qrcode {
		width: 110px;
		height: 110px;
		border: 2px solid rgba(255, 255, 255, 0.3);
		border-radius: 8px;
		background: #ffffff;
		margin-bottom: 10px;
		box-sizing: border-box;
		display: -webkit-box;
		display: -ms-flexbox;
		display: -webkit-flex;
		display: flex;
		-webkit-box-align: center;
		-ms-flex-align: center;
		-webkit-align-items: center;
		align-items: center;
		-webkit-box-pack: center;
		-ms-flex-pack: center;
		-webkit-justify-content: center;
		justify-content: center;
	}

	.footer-qrcode img {
		width: 100%;
		height: 100%;
		object-fit: contain;
