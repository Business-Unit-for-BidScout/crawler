			var text = $(this).text().trim() || '';
			
			// 发送点击埋点
			if (typeof sendBehaviorLog === 'function') {
				sendBehaviorLog('click', {
					type: '5200603201',
					typeName: '点击-页面底部-友情链接',
					value: {
						text: text
					}
				});
			}
		});
		
		// 页面底部-网站声明点击埋点
		$('.footer-web-state-link').on('click', function(e) {
			// 发送点击埋点
