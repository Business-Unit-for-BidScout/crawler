<script>
    $(document).ready(function () {
        var url = getFreecms() +'/rest/v1/notice/statisticsVisits.do';
        var nowTime = new Date().getTime();
        var encryptContent = hex_md5(hex_sha1(nowTime+'_'+String(url).split('?')[0]+'_bosssoft_platform_095285'));
        $.ajax({
            type: 'GET',
            url: getFreecms() +'/rest/v1/notice/statisticsVisits.do',
            headers:{
                'nsssjss':encryptByRSA(getFreecms() +'/rest/v1/notice/statisticsVisits.do' + '$$'+ new Date().getTime()),
                'time':nowTime,
                'url':url,
                'sign':encryptContent
            },
            contentType: "application/json;charset=utf-8",
            success: function (res) {
                var visitAll = res.data.totalVisits;
                $(".views_number").append(visitAll);
            }
        });
    })
</script>

</section>
<script>
    <!--验证码刷新-->
    function refreshCode() {
        $("#code_img").attr(
            "src",
            getFreecms() + "/verify/verifyCode.do?createTypeFlag=n&name=notice&d"
            + new Date().getTime());
    }
    layui.config({
        base: '/cms-sx/site/shanxi//resources/module/'
    }).extend({
        treeSelect: 'treeSelect/treeSelect'
    });
    $(document).ready(function () {
        function formatDateTime(date) {
            var year = date.getFullYear();
            var month = (date.getMonth() + 1).toString().padStart(2, '0');
            var day = date.getDate().toString().padStart(2, '0');
            var hours = date.getHours().toString().padStart(2, '0');
            var minutes = date.getMinutes().toString().padStart(2, '0');
            var seconds = date.getSeconds().toString().padStart(2, '0');
            return year + '-' + month + '-' + day + ' ' + hours + ':' + minutes + ':' + seconds;
        }
        $('#stateDate').val(getDay(0));
        $('#endDate').val(formatDateTime(new Date()));
        var selectTimeName='noticeTime';
        var siteId = 'a7a15d60-de5b-42f2-b35a-7e3efc34e54f';
        var channel = '1eb454a2-7ff7-4a3b-b12c-12acc2685bd1';
        var noticeType ='00101,001011';
        var regionCode = '610001';
        var purchaseManner='';
        //当前页
        var currPage =1;
        var pageSize ='10';
        var total='';
        // 开始时间
        var operationStartTime = '';
        // 结束时间
        var operationEndTime = formatDateTime(new Date());
        // 公告标题
        var title = '';
        var openTenderCode = '';
        var purchaseNature='';
        //123 主页信息公告    124 购买服务信息公告
        var xxggType='123';
        var govService='1';
        var cityOrArea='';
        //验证码
        var verifyCode = '';
        verifyCode = $('#verifycode').val();
        //区域下拉数据
        layui.use(['form','treeSelect'], function(){
            var treeSelect1= layui.treeSelect;
            treeSelect1.render({
                // 选择器
                elem: '#tree',
                // 数据
                data: '/cms-sx/site/shanxi/resources/json/sxTree.json',
                // 异步加载方式：get/post，默认get
                type: 'get',
                // 占位符
                placeholder: '请选择区域',
                // 是否开启搜索功能：true/false，默认false
                search: true,
                // 点击回调
                click: function(d){
                    regionCode = d.current.regionCode;
                    if(d.current.regionCode!="-1"){
                        $('#areaNews').find('li[codes='+regionCode+']').addClass('xxggActive').siblings().removeClass('xxggActive');
                    }else{
                        $('#areaNews').find('li[codeName="全部"]').addClass('xxggActive').siblings().removeClass('xxggActive');
                        regionCode=''
                    }
                    if(d.current.leaf=="0") {
                        cityOrArea = '6';
                    }else{
                        cityOrArea = '';
                    }
                    getDataList(channel,currPage, pageSize, noticeType, regionCode);
                },
                success:function(d){
                  
                  //区域点击
                  // console.log(treeSelect1)
                  $('.areaListUl li').on('click',(function(treeSelect1){
                    return function() {     
                      $(this).addClass('xxggActive').siblings().removeClass('xxggActive');
                        regionCode = $(this).attr('codes');
                        cityOrArea = '6'
                        var selectId = ''
                        for(var i=0;i<d.data.length;i++) {
                          if (d.data[i].regionCode == regionCode){
                            selectId = d.data[i].id
                            break
                          }

                        }
                        treeSelect1.checkNode('tree',selectId)
                        // var select = 'li[code=' + regionCode + ']';
                        // var selectId = $('#tree').siblings("div.layui-treeSelect").find('div.layui-treeSelect-body').find(select).attr('id')
                        // if(regionCode!=-1){
                        //     $('#tree').siblings("div.layui-treeSelect").find('div.layui-treeSelect-body').find(select).find('a').click(function(event){event.stopPropagation()});
                        // }else{
                        //     $('#tree').siblings("div.layui-treeSelect").find('div.layui-treeSelect-body').find(select).find('a').click(function(event){event.stopPropagation()});
                        //     regionCode=''
                        // }
                        getDataList(channel,currPage, pageSize, noticeType, regionCode);
                    };
                  })(treeSelect1))
                }
            });
        });

        //GetRequest在publicMethods.js文件里写的
        var urlParams=GetRequest();
        xxggType=urlParams.xxggType?urlParams.xxggType:xxggType;
        noticeType = urlParams.noticeType?urlParams.noticeType:noticeType;
        //判断noticeType是什么公告类型并激活当前类名,执行函数
        function IsnoticeType(){
            if(noticeType){
                if(xxggType=='123'){
                    $('.xxggIndex').show();
                    $('.xxggGmfw').hide();
                }else{
                    $('.xxggGmfw').show();
                    $('.xxggIndex').hide();
                }
                // 获取信息公告栏目页左侧公告区域li
                // var zcs = document.querySelectorAll('.xxggIndex > li');
                // var typeMap = {
                //     0: '00101,001011',
                //     1: '00102',
                //     2: '00103',
                //     3: '001004',
                //     4: '00105',
                //     5: '001059',
                //     6: '59',
                //     7: '001054',
                //     8: '00105A',
                //     9: '001061',
                //     10: '00105B,001062'
                // }
                // for (var k in typeMap) {
                //     if (typeMap[k] === noticeType || typeMap[k] === decodeURIComponent(noticeType)) {
                //         console.log(zcs[k].classList);
                //         zcs[k].classList.add('xxggActive');
                //         // console.log(zcs[k].classList);
                //     } else if(zcs[k].classList.contains('xxggActive')){
                //         zcs[k].classList.remove('xxggActive');
                //         console.log(111);
                //         console.log(zcs[k]);
                //         console.log(222);
                //     } else if(noticeType === "00101" && k==10) {
                //         zcs[0].classList.add('xxggActive');
                //         console.log(zcs[0]);
                //     }
                // }

                // dom元素循环用each方法
                $(".xxggIndex li").each(function(){
                    if(noticeType===$(this).attr("codes") || $(this).attr("codes")===decodeURIComponent(noticeType)){
                        $(this).addClass('xxggActive').siblings().removeClass('xxggActive');
                    }
                });
                $(".xxggGmfw li").each(function(){
                    if(noticeType===$(this).attr("codes") || $(this).attr("codes")===decodeURIComponent(noticeType)){
                        $(this).addClass('xxggActive').siblings().removeClass('xxggActive');
                    }
                });
                // 获取购买服务公告栏目页左侧公告区域li
                // var zcs1= document.querySelectorAll('.xxggGmfw > li');
                // var typeMap1 = {
                //     0: '00101,001011',
                //     1: '00105',
                //     2: '00102'
                // }
                // for (var l in typeMap1) {
                //     if (typeMap1[l] === noticeType || typeMap1[l] === decodeURIComponent(noticeType)) {
                //         zcs1[l].classList.add('xxggActive');
                //     } else if(zcs1[l].classList.contains('xxggActive')){
                //         zcs1[l].classList.remove('xxggActive');
                //     } else if(noticeType === "00101,001011") {
                //         zcs1[0].classList.add('xxggActive');
                //     }
                // }

            }
        }

        //调用执行函数
        IsnoticeType();
        //123 主页信息公告 124 购买服务信息公告
        if(xxggType=='123'){
            noticeType=noticeType;
            channel='1eb454a2-7ff7-4a3b-b12c-12acc2685bd1';
            $('.xxggIndex').show();
            $('.xxggGmfw').hide();
            // getDataList(channel,currPage, pageSize,noticeType,regionCode);
        }else if(xxggType=='124'){
            noticeType=noticeType;
            channel='1eb454a2-7ff7-4a3b-b12c-12acc2685bd1';
            $('.xxggGmfw').show();
            $('.xxggIndex').hide();
            // getDataList(channel,currPage, pageSize,noticeType,regionCode);
        }
        
        //公告类型点击
        $('.noticeType ul li').click(function () {
            $(this).addClass('xxggActive').siblings().removeClass('xxggActive');
            noticeType = $(this).attr('codes');
            getDataList(channel,currPage, pageSize, noticeType, regionCode);
        });

        //列表数据加载
        function getDataList(channel,currPage, pageSize,  noticeType,  regionCode,resetting) {
            if (resetting) {
                if(xxggType=='123'){
                    noticeType='00101,001011';
                }else{
                    //暂定 以防以后修改
                    noticeType='00101,001011';
                }
                regionCode = '610001';
                purchaseManner = '';
                $('.noticeType ul li').eq(0).addClass('xxggActive').siblings().removeClass('xxggActive');
                $('#areaNews li').eq(0).addClass('xxggActive').siblings().removeClass('xxggActive');
                var select = 'dd[lay-value=' + -1 + ']';
                var selectTree = 'li[code=' + -1 + ']';
                $('#tree').siblings("div.layui-treeSelect").find('div.layui-treeSelect-body').find(selectTree).find('a').click();
                $('#purchaseNature ').siblings("div.layui-form-select").find('dl').find(select).click();
                $('#purchaseManner').siblings("div.layui-form-select").find('dl').find(select).click();
                title = $('#titleName').val('');
                openTenderCode = $('#purchaseNumber').val('');
                purchaseNature = '';
                operationStartTime = $('#stateDate').val('');
                operationEndTime = $('#endDate').val('');
                getDataList(channel,currPage, pageSize, noticeType, regionCode);
            }
            //采购方式选择
            layui.use(['form'], function(){
                var form = layui.form;
                form.on('select(caigoufangshiNews)', function(data){
                    if(data.value!="-1"){
                        purchaseManner = data.value;
                    }else{
                        purchaseManner = '';
                    }
                });
                form.on('select(pingmuNews)', function(data){
                    if(data.value!="-1"){
                        purchaseNature = data.value;
                    }else{
                        purchaseNature = '';
                    }
                });
            });

            title = $('#titleName').val();
            openTenderCode = $('#purchaseNumber').val();
            // 计算日期范围
            var today2 = new Date();
            var threeYearsAgo2 = new Date();
            threeYearsAgo2.setFullYear(today2.getFullYear() - 3);
            operationStartTime = $('#stateDate').val() || formatDateTime(new Date(threeYearsAgo2));
            operationEndTime = $('#endDate').val()|| formatDateTime(new Date(today2));
            verifyCode = $('#verifycode').val();
            if(xxggType=='124'){
                var data = '?&siteId=' + siteId + '&channel=' + channel + '&currPage=' + currPage + '&pageSize=' + pageSize + '&' + 'noticeType' + '=' + noticeType +
                    '&regionCode=' + regionCode+'&purchaseManner='+ purchaseManner+'&title='+ title+'&verifyCode='+ verifyCode+
                    '&openTenderCode=' + openTenderCode+
                    '&purchaseNature=' + purchaseNature+'&operationStartTime='+ operationStartTime+'&operationEndTime='+ operationEndTime+"&selectTimeName="+selectTimeName+"&govService="+govService+"&cityOrArea="+cityOrArea;
            }else{
                var data = '?&siteId=' + siteId + '&channel=' + channel + '&currPage=' + currPage + '&pageSize=' + pageSize + '&' + 'noticeType' + '=' + noticeType +
                    '&regionCode=' + regionCode+'&purchaseManner='+ purchaseManner+'&title='+ title+'&verifyCode='+ verifyCode+
                    '&openTenderCode=' + openTenderCode+
                    '&purchaseNature=' + purchaseNature+'&operationStartTime='+ operationStartTime+'&operationEndTime='+ operationEndTime+"&selectTimeName="+selectTimeName+"&cityOrArea="+cityOrArea;
            }
            var url = getFreecms() +'/rest/v1/notice/selectInfoMoreChannel.do';
            var nowTime = new Date().getTime();
            var encryptContent = hex_md5(hex_sha1(nowTime+'_'+String(url).split('?')[0]+'_bosssoft_platform_095285'));
            $.ajax({
                type: 'GET',
                url: getFreecms()+'/rest/v1/notice/selectInfoMoreChannel.do' + data,
                headers:{
                    'nsssjss':encryptByRSA(getFreecms() +'/rest/v1/notice/selectInfoMoreChannel.do' + '$$'+ new Date().getTime()),
                    'time':nowTime,
                    'url':url,
                    'sign':encryptContent
                },
                contentType: "application/json;charset=utf-8",
                success: function (res) {
                    var obj = res.data;
                    // 分页
                    total = res.total;
                    new Page({
                        id: 'pagination',
                        pageTotal: Math.ceil((total / pageSize)), //必填,总页数
                        pageAmount: pageSize,  //每页多少条
                        dataTotal: total, //总共多少条数据
                        curPage:currPage, //初始页码,不填默认为1
                        pageSize: 5, //分页个数,不填默认为5
                        showPageTotalFlag:true, //是否显示数据统计,不填默认不显示
                        showSkipInputFlag:true, //是否支持跳转,不填默认不显示
                        getPage: function (page) {
                            //获取当前页数
                            currPage = page;
                            getDataList(channel,currPage, pageSize, noticeType, regionCode);
                        }
                    });
                    $(".noticeListUl").empty();
                    if(res.code == -1) {
                        $("#verifycode").val("");
                        refreshCode();
                        alert("验证码错误或已失效，请重新输入");
                        $("#pagination").hide();
                        $("#verifycodefinshed").show();
                    }else if (obj.length > 0) {
                        for (var i = 0; i < obj.length; i++) {
                            var htmlTr = '';
                            var num=i+1;
                            var time = obj[i].noticeTime;
                            if(time){
                                time = time.substr(0, 10);
                            }else{
                                time = '无'
                            }
                            var titleVal='';
                            // 给公告标题带有(已撤销)字眼的文本变成红色字体
                            if(obj[i].title && obj[i].title.indexOf("(已撤销)")===-1){
                                titleVal = obj[i].title;
                            }else if(obj[i].title && obj[i].title.indexOf("(已撤销)")){
                                titleVal = obj[i].title.replace(/\(已撤销\)/, "<font color=red>$&</font>");
                            }else{
                                titleVal = ''
                            }
                            var regionName = '';
                            if(obj[i].regionName){
                                regionName = obj[i].regionName;
                            }else{
                                regionName = '无'
                            }
                            var url=obj[i].pageurl+'?'+'noticeType='+obj[i].noticeType+'&noticeId='+obj[i].id;
                            htmlTr='<li>' +
                                '<a href="'+ url + '"  target="_blank">' +
                                '<span>'+ (10 * (currPage - 1) + num) +'</span>' +
                                '<span>'+regionName+'</span>' +
                                '<span>'+titleVal+'</span>' +
                                '<span>'+time+'</span>' +
                                '</a>' +
                                '</li>';
                            $(".noticeListUl").append(htmlTr);
                        }
                        $("#pagination").show()
                        $("#verifycodefinshed").hide();
                    } else {
                        $(".noticeListUl").append('<p style="text-align: center;margin-top: 40px;">暂无数据</p>');
                        $("#pagination").hide()
                        $("#verifycodefinshed").hide();
                    }

                }
            });
        }
        // 查询
        $("#Inquire").click(function () {
            currPage = 1;
            getDataList(channel,currPage, pageSize,noticeType,regionCode);
        });
        //重置
        $('#queryReset').click(function () {
            regionCode='';
            getDataList(channel,currPage, pageSize,noticeType,regionCode,1);
        });

        //layui初始化加载
        layui.use(['form', 'layedit', 'laydate'], function(){
            var form = layui.form
                ,laydate = layui.laydate;

             // 日期格式化函数
            function formatDate(date) {
                var year = date.getFullYear();
                var month = (date.getMonth() + 1).toString().padStart(2, '0');
                var day = date.getDate().toString().padStart(2, '0');
                var hours = date.getHours().toString().padStart(2, '0');
                var minutes = date.getMinutes().toString().padStart(2, '0');
                var seconds = date.getSeconds().toString().padStart(2, '0');
                return year + '-' + month + '-' + day + ' ' + hours + ':' + minutes + ':' + seconds;

            }

            // 计算日期范围
            var today = new Date();
            var threeYearsAgo = new Date();
            threeYearsAgo.setFullYear(today.getFullYear() - 3);

            var minDateStr = formatDate(threeYearsAgo);
            var maxDateStr = formatDate(today);

            //日期
            laydate.render({
                elem: '#stateDate',
                min: minDateStr,
                max: maxDateStr,
                type: 'datetime',
                trigger:'click'
            });
            laydate.render({
                elem: '#endDate',
                min: minDateStr,
                max: maxDateStr,
                type: 'datetime',
                trigger:'click',
            });
            form.render();
        });
    })
</script>
<style>
    .ztree li span.button{
        width: 0;
    }
    .layui-treeSelect .ztree li span.button.ico_docu:before{
        content: "";
    }
    .layui-treeSelect .ztree li a.curSelectedNode{
        color: #3888fe;
    }
    .layui-treeSelect.layui-form-select .layui-anim{
        width: 187px!important;
        overflow-x: auto;
    }
    .layui-form-select dl::-webkit-scrollbar,.layui-treeSelect.layui-form-select .layui-anim::-webkit-scrollbar{
        width: 2px!important;
        height: 5px!important;
        border-radius: 10px;
        background-color: #F5F5F5;
    }
</style>
