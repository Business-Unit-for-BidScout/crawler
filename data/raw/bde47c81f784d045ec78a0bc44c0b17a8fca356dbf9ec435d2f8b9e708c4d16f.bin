    <script>
        $(function() {
            var sc = $(document),
                win = $(window);

            win.scroll(function() {
                if (sc.scrollTop() > 200) {
                    $('.backtop').fadeIn();
                } else {
                    $('.backtop').fadeOut();
                }
            })

            $('.backtop').click(function() {
                $("html,body").animate({
                    "scrollTop": 0
                }, 500);
            })

        })
    </script>
