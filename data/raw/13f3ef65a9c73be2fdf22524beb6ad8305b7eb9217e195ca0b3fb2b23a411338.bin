            $(this).children("li").each(function (index) {
                $(this).click(function () {
                    $(this).addClass('columnCommonStylesTabActive').siblings().removeClass('columnCommonStylesTabActive');
                    aTabBodys.hide().eq(index).show();
                });
            });
        }
    });
