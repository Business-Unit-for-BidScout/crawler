<style>
    .article img.px50 {
        vertical-align: middle !important;}
    .article .textindent{
        text-indent: 0!important;}
        
     .art-main  table{min-width:6rem;    margin: 0px auto;}
.table-wapper{overflow-x: auto;}   
        
        
</style>
<script>
    $(function () {
        //  内容页小图标居左
        var img_len = $(".article img")
        img_len.each(function (i, item) {
            if ($(item).innerWidth() < 50) {
                $(item).addClass("px50")
            }
        })
        // 手机版内容页图片偏右
        $(".article img").parents("p").addClass("textindent")
        $(".article video").parents("p").addClass("textindent")
        $(".article iframe").parents("p").addClass("textindent")

    })
    
    
    
     $(function () {
         
            $('.art-main  table').wrap('<div class="table-wapper"></div>');
        })
</script>







