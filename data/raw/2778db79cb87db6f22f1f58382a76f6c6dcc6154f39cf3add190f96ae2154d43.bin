      settings: {
          dots: true,
          speed: 300,
          slidesToShow: 3,
          slidesToScroll: 1,
      }
    },
  ]
});

$('.lb-slick-right-a').slick({
        infinite: true,
        asNavFor:$('.lb-slick-a'),
        slidesToShow: 1,
        slidesToScroll: 1,
        autoplay: true,
        centerMode: false,
        arrows:true,
        dots:false,

});
$('.zy-slick').slick({
        infinite: true,
        slidesToShow: 3,
        slidesToScroll: 1,
        autoplay: true,
        centerMode: false,
        arrows:true,
        dots:false,
responsive: [
    {
      breakpoint: 1279,
      settings: {
          dots: false,
          speed: 300,
          slidesToShow: 3,
          slidesToScroll: 1,
      }
    },
    {
      breakpoint: 768,
      settings: {
          dots: true,
          speed: 300,
          slidesToShow: 2,
          slidesToScroll: 1,
      }
    },
  ]
});
$('.video-list').slick({
        infinite: true,
        slidesToShow: 2,
        slidesToScroll: 1,
        autoplay: true,
        centerMode: false,
        arrows:false,
        dots:true,

});






</script>
</body>
</html>
