<script>
    function init() {
        var str = window.location.pathname;
        if(str.indexOf("qwjsy")!=-1) {
            $(".search").remove();
        }
    };
    init();
    $(document).ready(function () {
        // 获取当前相对路径： /springmvc/page/frame/test.html
        var pathName = window.location.pathname + '?result=result';
        function getCaption(obj){
            var index=obj.indexOf("\/");
            obj=obj.substring(index+1,obj.length)   ;
            return obj;
        }
        var aList =  $(".nav-tab a")
        var liList =  $(".nav-tab li")
        var navUrl = ''
        for (var i = 0;i<aList.length;i++){
            var arrUrl = aList[i]["href"].split("//")[1];
            navUrl = '/'+getCaption(arrUrl);
            if(navUrl == pathName){
                liList.eq(i).addClass('activeList').siblings().removeClass('activeList');
            }
            if(arrUrl.indexOf("site")>=0){
                aList[i].target = '_self'
            }else{
                aList[i].target = '_blank'
            }
        }
    })

    $('#megaloscopeBtn1').click(function () {
        var title = $('#title').val();
        var megaloscopeHref = $('#megaloscopeHref1').attr('href');
        if (megaloscopeHref.indexOf("?") !=-1) {
            megaloscopeHref=megaloscopeHref.split("?")[0]
        }
        if(title) {
            $('#megaloscopeHref1').attr('href', encodeURI(megaloscopeHref + '?searchContentBT=' + title))
        }
    })
    $('#megaloscopeBtn2').click(function () {
        var title = $('#title').val();
        var megaloscopeHref = $('#megaloscopeHref2').attr('href');
        if (megaloscopeHref.indexOf("?") !=-1) {
            megaloscopeHref=megaloscopeHref.split("?")[0]
        }
        if(title) {
            $('#megaloscopeHref2').attr('href', encodeURI(megaloscopeHref + '?searchContentQW=' + title))
        }
    })
</script>


