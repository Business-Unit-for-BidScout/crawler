<script>
    $(document).ready(function () {
        var url = getFreecms() +'/rest/v1/notice/statisticsVisits.do';
        var nowTime = new Date().getTime();
        var encryptContent = hex_md5(hex_sha1(nowTime+'_'+String(url).split('?')[0]+'_bosssoft_platform_095285'));
        $.ajax({
            type: 'GET',
            url: getFreecms() +'/rest/v1/notice/statisticsVisits.do',
            headers:{
                'nsssjss':encryptByRSA(getFreecms() +'/rest/v1/notice/statisticsVisits.do' + '$$'+ new Date().getTime()),
                'time':nowTime,
                'url':url,
                'sign':encryptContent
            },
            contentType: "application/json;charset=utf-8",
            success: function (res) {
                var visitAll = res.data.totalVisits;
                $(".views_number").append(visitAll);
            }
        });
    })
</script>

