<script>
    // 动态创建iframe实现浏览器打印
    function onprint(){

        //判断iframe是否存在，不存在则创建iframe
        var iframe=document.getElementById("print-iframe");
        if(!iframe){
            var el = document.getElementById("print-content");
            iframe = document.createElement('IFRAME');
            var doc = null;
            iframe.setAttribute("id", "print-iframe");
            iframe.setAttribute("name", "print-iframe");
            iframe.setAttribute('style', 'position:absolute;width:0px;height:0px;left:-500px;top:-500px;');
            document.body.appendChild(iframe);
            doc = iframe.contentWindow.document;
            //这里可以自定义样式
            doc.write('<style media="print">@page {size: auto;margin: 0mm}</style>'); //解决出现页眉页脚和路径的问题
            doc.write('<div style="padding:25px 20px">' + el.innerHTML + '</div>');
            doc.close();
            iframe.contentWindow.focus();
        }
        setTimeout(function(){ iframe.contentWindow.print();},50)  //解决第一次样式不生效的问题
        if (navigator.userAgent.indexOf("MSIE") > 0){
            document.body.removeChild(iframe);
        }
        ft();
    }

    //  修改iframe内css样式
    function ft() {
        var deptObjs = document.getElementById("print-iframe").contentWindow.document.getElementsByTagName("h1");
        console.log(111)
        for (var i = 0; i < deptObjs.length; i++) {
            var tmp = deptObjs[i];
            if (tmp.className == "info-title") {
                //alert(tmp.style.display);
                tmp.style.height = "auto";
                //alert(tmp.style.display);
            }
        }
    }
  $(document).ready(function () {
    var id = "d5b23426-e36f-11ef-8063-08c0eb20c666";
    var currPage = 1;
    var pageSize = 10;
    // function printHtml(html) {
        // var bodyHtml = document.body.innerHTML;
        // document.body.innerHTML = html;
        // window.print()
        // document.body.innerHTML = bodyHtml;
    // }
    // function onprint() {
    //     var html = $("#print-content").html();
    //     printHtml(html);
    // }

    //字号
    $(".fontSize_16").click(function() {
        $(".info-article p,.info-article span").css({ fontSize: "16px" });
    });
    $(".fontSize_14").click(function() {
        $(".info-article p,.info-article span").css({ fontSize: "14px" });
    });
    $(".fontSize_12").click(function() {
        $(".info-article p,.info-article span").css({ fontSize: "12px" });
    });
    function isIE() {
        if (!!window.ActiveXObject || "ActiveXObject" in window)
            return true;
        else
            return false;
    }
    function download(filename,name) {

        new FileDownloader({
            url: encodeURI(filename),
            filename: name
        })
    }
    function getDataList(id) {
        var data = '?currPage=' + currPage + '&pageSize=' + pageSize  + '&id=' + id ;

        $("#info_download").innerHTML="";
        var url = getFreecms() +'/rest/v1/notice/selectNoticeDocInfo.do';
        var nowTime = new Date().getTime();
        var encryptContent = hex_md5(hex_sha1(nowTime+'_'+String(url).split('?')[0]+'_bosssoft_platform_095285'));
        $.ajax({
            type: 'GET',
            url: getFreecms() +'/rest/v1/notice/selectNoticeDocInfo.do' + data,
            headers:{
                'nsssjss':encryptByRSA(getFreecms() +'/rest/v1/notice/selectNoticeDocInfo.do' + '$$'+ new Date().getTime()),
                'time':nowTime,
                'url':url,
                'sign':encryptContent
            },
            contentType: "application/json;charset=utf-8",
            success: function (res) {
                var obj = res.data;

                var data = new Date().valueOf();

                var info_download = '' ;
                if (obj.length > 0) {
                    for (var i = 0; i < obj.length; i++) {
                        var app = {};
                        app.id = obj[i].id;
                        var filename = obj[i].fileUrl+'?t='+data;
                        var name = obj[i].fileName;
                        if(isIE()){
                            info_download +='<a href="'+filename+'"  target="_blank">'+'点击下载  :  '+obj[i].fileName+'</a>'+'<br>';
                        }else{
                            info_download +='<a href="'+filename+'"  target="_blank" style="color: #f30">'+''+obj[i].fileName+'</a>'+'<br>';
                            // info_download += '<button class="info_download" style="color: #f30"  onclick="download(\''+filename+'\',\''+name+'\')"  >'+'点击下载  :  '+obj[i].fileName+'</button>'+'<br>'
                        }
                    }
                    $("#info_download").append(info_download);


                }

            }
        });

    }
    //获取附件列表
    function getFileList (id) {
      var data = '?objid=' + id ;
      $("#file_list").innerHTML="";
      var url = getFreecms() +'/rest/v1/notice/selectUploadFile.do';
      var nowTime = new Date().getTime();
      var encryptContent = hex_md5(hex_sha1(nowTime+'_'+String(url).split('?')[0]+'_bosssoft_platform_095285'));
      $.ajax({
          type: 'GET',
          url: getFreecms() +'/rest/v1/notice/selectUploadFile.do' + data,
          headers:{
              'nsssjss':encryptByRSA(getFreecms() +'/rest/v1/notice/selectUploadFile.do' + '$$'+ new Date().getTime()),
              'time':nowTime,
              'url':url,
              'sign':encryptContent
          },
          contentType: "application/json;charset=utf-8",
          success: function (res) {
            var obj = res.uploadfileList;
                var data = new Date().valueOf();
                var info_file = '' ;
                if (obj.length > 0) {
                    for (var i = 0; i < obj.length; i++) {
                        var app = {};
                        app.id = obj[i].id;
                        var filepath = obj[i].filepath;
                        var name = obj[i].filename;
                        if(isIE()){
                            info_file +='<a href="/freecms'+filepath+'"  target="_blank">'+'点击下载  :  '+name+'</a>'+'<br>';
                        }else{
                            info_file +='<a href="/freecms'+filepath+'"  target="_blank" style="color: #f30">'+''+name+'</a>'+'<br>';
                        }
                    }
                    $("#file_list").append(info_file);
                }
          }
        })
    }
    if(id) {
        getDataList(id)
        getFileList(id)
    }
  })
</script>
