<script src="http://res2.wx.qq.com/open/js/jweixin-1.6.0.js" type="text/javascript"></script>
<script>
	wx.config({
		debug: false, // 开启调试模式,调用的所有api的返回值会在客户端alert出来，若要查看传入的参数，可以在pc端打开，参数信息会通过log打出，仅在pc端时才会打印。
		appId: "wx552edf6fc2e6d754", // 必填，公众号的唯一标识
		timestamp: "1783783112", // 必填，生成签名的时间戳
		nonceStr: "B4ZIz5nO", // 必填，生成签名的随机串
		signature: "ee8e574bda23b2236245111d1b1bc3fe7de27f8a",// 必填，签名
		jsApiList: ['updateAppMessageShareData','updateTimelineShareData'] // 必填，需要使用的JS接口列表
	});
	

	wx.ready(function(){
		//自定义“分享给朋友”及“分享到QQ”按钮的分享内容
		wx.updateAppMessageShareData({
			title: "汉中市铁路中心医院关于2024年招聘疼痛科医生岗位考试的公告-汉中市第一医院（汉中市妇女儿童医院）", // 分享标题
